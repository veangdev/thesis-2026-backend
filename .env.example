# Application
NODE_ENV=development
PORT=3000
APP_PREFIX=api/v1

# Database
# Local (host) connects to the Postgres container published on 5433.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pnc_journey_star?schema=public"

# JWT — use long, random values in real environments (min 16 chars each)
JWT_ACCESS_SECRET=change-me-access-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
