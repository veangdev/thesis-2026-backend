# Application
NODE_ENV=development
PORT=8000
APP_PREFIX=api/v1

# Database
# Local (host) connects to the Postgres container published on 5433.
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/pnc_journey_star?schema=public"

# JWT — use long, random values in real environments (min 16 chars each)
JWT_SECRET=change-me-access-secret-min-16-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-16-chars
JWT_REFRESH_EXPIRES_IN=7d

# CORS — frontend dev server origin (comma-separated to allow several)
CORS_ORIGIN=http://localhost:3000

# Mail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=vansaozhang@gmail.com
SMTP_PASS=urmvbdqaavvskpcc
MAIL_FROM="PNC Journey Star <vansaozhang@gmail.com>"
